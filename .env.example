# Copy to .env and adjust for your machine. The pipeline reads only these two paths; everything else
# derives from FTO_ADMET_ROOT. Nothing project-related goes in $HOME.

# Repo root on persistent storage (code, ledger, outputs)
FTO_ADMET_ROOT=/zfs/sanjanp/fto-admet

# Envs, package caches, and model weights (same /zfs volume; keeps pixi hardlinking working)
FTO_ADMET_ENV_CACHE=/zfs/sanjanp/fto-admet-envs
