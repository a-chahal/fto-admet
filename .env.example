# copy to .env and set these paths for your machine. the pipeline reads these; everything else derives
# from FTO_ADMET_ROOT. keep project data off your home volume.

# repo root on persistent storage (code, run ledger, outputs)
FTO_ADMET_ROOT=/path/to/fto-admet

# environments, package caches, and model weights (put on the same volume as the root so pixi can hardlink)
FTO_ADMET_ENV_CACHE=/path/to/fto-admet-envs

# optional, only to run opera (out-of-band matlab runtime): the installed opera dir holding run_OPERA.sh,
# and the matlab compiler runtime version dir.
# OPERA_HOME=/path/to/opera/application
# MCR_ROOT=/path/to/opera/mcr
